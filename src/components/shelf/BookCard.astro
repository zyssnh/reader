---
/**
 * BookCard 组件
 * 书架卡片：封面 + 书名 + 作者 + 进度
 */
export interface Props {
  id: string;
  title: string;
  author: string;
  cover?: string;
  format: 'epub' | 'txt';
  totalChapters: number;
  lastChapterId?: string;
  customTitle?: string;
  customAuthor?: string;
}
const { id, title, author, cover, format, totalChapters, lastChapterId, customTitle, customAuthor } = Astro.props;

const displayTitle = customTitle || title;
const displayAuthor = customAuthor || author;

// 根据 id hash 生成渐变背景色
function hashColor(s: string): string[] {
  let h = 0;
  for (let i = 0; i < s.length; i++) h = ((h << 5) - h) + s.charCodeAt(i) | 0;
  const hue = Math.abs(h) % 360;
  return [`hsl(${hue}, 40%, 25%)`, `hsl(${(hue + 40) % 360}, 35%, 20%)`];
}
const [c1, c2] = hashColor(id);
---

<div
  class="book-card"
  data-book-id={id}
  data-format={format}
  data-title={displayTitle}
  data-author={displayAuthor}
  data-chapters={String(totalChapters)}
>
  <a href={`/reader/read?id=${id}`} class="book-card-link" aria-label={`阅读《${displayTitle}》`}>
    <div class="book-cover">
      {cover
        ? <img src={cover} alt={displayTitle} loading="lazy" />
        : <div class="book-cover-placeholder" style={`background: linear-gradient(135deg, ${c1}, ${c2});`}>
            <span class="book-cover-letter">{displayTitle.charAt(0)}</span>
          </div>
      }
    </div>
    <div class="book-info">
      <div class="book-title" title={displayTitle}>{displayTitle}</div>
      <div class="book-meta">
        <span>{displayAuthor}</span>
        <span class="book-format">{format.toUpperCase()}</span>
      </div>
      <div class="book-progress">
        <div class="book-progress-bar">
          <div class="book-progress-fill" style={`width:${lastChapterId ? Math.round((totalChapters > 0 ? Math.min(1, (parseInt(lastChapterId) + 1) / totalChapters) : 0) * 100) : 0}%`}></div>
        </div>
        <span class="book-progress-text">{lastChapterId ? `${Math.round((totalChapters > 0 ? Math.min(1, (parseInt(lastChapterId) + 1) / totalChapters) : 0) * 100)}%` : '新书'}</span>
      </div>
    </div>
  </a>
</div>

<style>
  .book-card {
    border: 1px solid var(--border);
    border-radius: var(--radius);
    background: var(--bg-card);
    overflow: hidden;
    transition: all 0.15s ease;
  }

  .book-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.3);
    border-color: var(--border-strong);
  }

  .book-card-link {
    text-decoration: none;
    color: inherit;
    display: flex;
    flex-direction: column;
  }

  .book-cover {
    width: 100%;
    aspect-ratio: 2 / 3;
    overflow: hidden;
    background: var(--bg-surface);
  }

  .book-cover img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .book-cover-placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .book-cover-letter {
    font-family: var(--font-serif);
    font-size: 48px;
    color: rgba(255, 255, 255, 0.5);
    user-select: none;
  }

  .book-info {
    padding: var(--space-3);
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
  }

  .book-title {
    font-size: 14px;
    font-weight: 600;
    color: var(--text-primary);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .book-meta {
    display: flex;
    align-items: center;
    justify-content: space-between;
    font-family: var(--font-mono);
    font-size: 10px;
    color: var(--text-muted);
    letter-spacing: 0.06em;
  }

  .book-format {
    padding: 1px var(--space-1);
    border: 1px solid var(--border);
    border-radius: calc(var(--radius) - 2px);
    font-size: 9px;
  }

  .book-progress {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    margin-top: var(--space-1);
  }

  .book-progress-bar {
    flex: 1;
    height: 3px;
    background: var(--border);
    border-radius: 2px;
    overflow: hidden;
  }

  .book-progress-fill {
    height: 100%;
    background: var(--accent-green);
    border-radius: 2px;
    transition: width 0.3s ease;
  }

  .book-progress-text {
    font-family: var(--font-mono);
    font-size: 10px;
    color: var(--text-muted);
    letter-spacing: 0.06em;
  }
</style>
