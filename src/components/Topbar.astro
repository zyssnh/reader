---
/**
 * Topbar 组件
 * 顶部导航栏：logo、书名+进度条、快捷操作按钮
 */
---

<div class="topbar" id="topbar">
  <div class="topbar-left">
    <a href="/" class="topbar-logo" aria-label="Reader 首页">
      <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/>
        <path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/>
      </svg>
      <span class="topbar-brand">Reader</span>
    </a>
  </div>

  <div class="topbar-center" id="topbar-center" style="display:none;">
    <span class="topbar-book-title" id="topbar-book-title"></span>
    <div class="topbar-progress" id="topbar-progress-container">
      <div class="topbar-progress-bar" id="topbar-progress-bar" style="width:0%"></div>
    </div>
    <span class="topbar-progress-text" id="topbar-progress-text"></span>
  </div>

  <div class="topbar-right">
    <button class="topbar-btn" id="btn-sidebar-toggle" aria-label="切换侧边栏" title="目录">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/>
      </svg>
    </button>
    <button class="topbar-btn" id="btn-search" aria-label="搜索" title="搜索 (Ctrl+F)">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>
      </svg>
    </button>
    <button class="topbar-btn" id="btn-settings-toggle" aria-label="设置" title="设置面板">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83-2.83l.06-.06A1.65 1.65 0 0 0 4.68 15a1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 2.83-2.83l.06.06A1.65 1.65 0 0 0 9 4.68a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 2.83l-.06.06A1.65 1.65 0 0 0 19.4 9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"/>
      </svg>
    </button>
  </div>
</div>

<style>
  .topbar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 44px;
    padding: 0 var(--space-4);
    background: var(--bg-surface);
    border-bottom: 1px solid var(--border);
    flex-shrink: 0;
    user-select: none;
    -webkit-user-select: none;
  }

  .topbar-left {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    min-width: 120px;
  }

  .topbar-logo {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    color: var(--text-primary);
    text-decoration: none;
    font-family: var(--font-mono);
    font-size: 14px;
    letter-spacing: 0.06em;
  }

  .topbar-brand {
    color: var(--accent-blue);
  }

  .topbar-center {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 2px;
    max-width: 400px;
    margin: 0 var(--space-4);
  }

  .topbar-book-title {
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--text-secondary);
    letter-spacing: 0.06em;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    max-width: 100%;
  }

  .topbar-progress {
    width: 100%;
    height: 3px;
    background: var(--bg-card);
    border-radius: 2px;
    overflow: hidden;
  }

  .topbar-progress-bar {
    height: 100%;
    background: var(--accent-green);
    border-radius: 2px;
    transition: width 0.3s ease;
  }

  .topbar-progress-text {
    font-family: var(--font-mono);
    font-size: 10px;
    color: var(--text-muted);
    letter-spacing: 0.06em;
  }

  .topbar-right {
    display: flex;
    align-items: center;
    gap: var(--space-1);
  }

  .topbar-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 32px;
    height: 32px;
    border: 1px solid transparent;
    border-radius: var(--radius);
    background: transparent;
    color: var(--text-secondary);
    cursor: pointer;
    transition: all 0.15s ease;
  }

  .topbar-btn:hover {
    color: var(--text-primary);
    background: var(--bg-card);
    border-color: var(--border);
  }

  .topbar-btn:active {
    color: var(--accent-blue);
  }
</style>
