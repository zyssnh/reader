---
/**
 * TocPanel — 阅读器目录 (v3)
 *
 * 设计参考：Apple Books / 微信读书 / Readium
 * 桌面：320px 侧边栏，自然融入三栏布局
 * 移动端：85vw 覆盖式 Drawer
 *
 * 新增功能：
 * - 章节搜索（实时过滤）
 * - 分页/普通滚动切换
 * - 最近阅读区域
 * - 右键上下文菜单
 * - 拖拽下滑关闭（移动端）
 * - Ctrl+F 聚焦搜索
 * - 所有偏好 persisting 到 localStorage
 */
---

<!-- 移动端遮罩 -->
<div class="toc-backdrop" id="toc-backdrop" aria-hidden="true"></div>

<aside class="toc-panel" id="toc-panel" role="complementary" aria-label="目录">
  <!-- 移动端拖拽手柄 -->
  <div class="toc-drag-handle" aria-hidden="true"></div>

  <!-- Header -->
  <div class="toc-header">
    <span class="toc-heading">目录</span>
    <span class="toc-header-meta">
      <span class="toc-chapter-count" id="toc-count">-</span>
      <button class="toc-hdr-btn" id="toc-btn-collapse-all" aria-label="折叠全部" title="折叠全部">
        <svg width="14" height="14" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><polyline points="4 6 8 10 12 6"/></svg>
      </button>
      <button class="toc-hdr-btn" id="toc-btn-scroll-mode" aria-label="切换滚动模式" title="切换滚动模式">
        <svg class="toc-mode-icon-normal" width="14" height="14" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="2" y="2" width="12" height="12" rx="1"/><line x1="2" y1="6" x2="14" y2="6"/><line x1="2" y1="10" x2="14" y2="10"/></svg>
        <svg class="toc-mode-icon-page" width="14" height="14" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M2 3h5v10H2z"/><path d="M9 3h5v10H9z"/></svg>
      </button>
      <button class="toc-hdr-btn toc-close-btn" id="toc-close-btn" aria-label="关闭目录" title="关闭目录">
        <svg width="14" height="14" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><line x1="4" y1="4" x2="12" y2="12"/><line x1="12" y1="4" x2="4" y2="12"/></svg>
      </button>
    </span>
  </div>

  <!-- 搜索框 -->
  <div class="toc-search-wrap" id="toc-search-wrap">
    <svg class="toc-search-icon" width="14" height="14" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="7" cy="7" r="5"/><line x1="11" y1="11" x2="14" y2="14"/></svg>
    <input type="text" class="toc-search-input" id="toc-search-input" placeholder="搜索章节…" autocomplete="off" />
    <span class="toc-search-count" id="toc-search-count"></span>
  </div>


  <!-- 导航滚动区 -->
  <nav class="toc-nav" id="toc-nav" aria-label="章节目录">
    <ul class="toc-tree" id="toc-tree" role="tree"></ul>

    <!-- 空搜索结果 -->
    <div class="toc-empty" id="toc-empty" style="display:none;">
      <p>没有匹配的章节</p>
    </div>
  </nav>

  <!-- 分页控件（分页模式时显示） -->
  <div class="toc-pagination" id="toc-pagination" style="display:none;">
    <button class="toc-page-btn" id="toc-page-prev" aria-label="上一页">
      <svg width="12" height="12" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2"><polyline points="10 4 6 8 10 12"/></svg>
    </button>
    <span class="toc-page-info" id="toc-page-info">第 1 / 1 页</span>
    <button class="toc-page-btn" id="toc-page-next" aria-label="下一页">
      <svg width="12" height="12" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2"><polyline points="6 4 10 8 6 12"/></svg>
    </button>
  </div>
</aside>

<!-- 右键上下文菜单 -->
<div class="toc-context-menu" id="toc-context-menu" style="display:none;">
  <button data-action="copy-title">复制标题</button>
  <button data-action="bookmark">🔖 添加书签</button>
</div>

<style>
  /* ═══════════════════════════════════
     Panel + Backdrop
     ═══════════════════════════════════ */
  .toc-backdrop { display:none; position:fixed; inset:0; background:rgba(0,0,0,.45); z-index:149; }

  .toc-panel {
    width: 320px; min-width: 320px;
    background: #181A1F;
    border-right: 1px solid var(--border, #30363d);
    display: flex; flex-direction: column;
    overflow: hidden; flex-shrink: 0;
    z-index: 150;
  }

  .toc-drag-handle { display:none; width:32px; height:4px; margin:8px auto 0; border-radius:2px; background:rgba(255,255,255,.2); }

  /* ═══════════════════════════════════
     Header
     ═══════════════════════════════════ */
  .toc-header {
    display: flex; align-items: center; justify-content: space-between;
    padding: 12px 16px; border-bottom: 1px solid var(--border, #30363d); flex-shrink: 0;
  }
  .toc-heading { font-size: 15px; font-weight: 600; color: #E5E7EB; }
  .toc-header-meta { display: flex; align-items: center; gap: 4px; }
  .toc-chapter-count {
    font-family: var(--font-mono, monospace); font-size: 11px;
    color: #6B7280; letter-spacing: 0.06em; margin-right: 4px;
  }
  .toc-hdr-btn {
    display: flex; align-items: center; justify-content: center;
    width: 28px; height: 28px; border: none; border-radius: 5px;
    background: transparent; color: #6B7280; cursor: pointer;
    transition: background 0.15s, color 0.15s;
  }
  .toc-hdr-btn:hover { background: rgba(255,255,255,.08); color: #E5E7EB; }
  .toc-hdr-btn.active { color: #60A5FA; background: rgba(59,130,246,.15); }

  /* 模式图标切换 */
  .toc-mode-icon-page { display: none; }
  .toc-panel[data-scroll-mode="page"] .toc-mode-icon-normal { display: none; }
  .toc-panel[data-scroll-mode="page"] .toc-mode-icon-page { display: block; }

  /* ═══════════════════════════════════
     Search
     ═══════════════════════════════════ */
  .toc-search-wrap {
    display: flex; align-items: center; gap: 8px;
    padding: 8px 16px; border-bottom: 1px solid var(--border, #30363d); flex-shrink: 0;
  }
  .toc-search-icon { color: #6B7280; flex-shrink: 0; }
  .toc-search-input {
    flex: 1; border: none; background: transparent;
    color: #E5E7EB; font-size: 13px; outline: none; font-family: inherit;
    min-width: 0;
  }
  .toc-search-input::placeholder { color: #4B5563; }
  .toc-search-count { font-family: var(--font-mono, monospace); font-size: 10px; color: #6B7280; display: none; }
  .toc-search-count.visible { display: inline; }


  /* ═══════════════════════════════════
     Tree
     ═══════════════════════════════════ */
  .toc-nav {
    flex: 1; overflow-y: auto; overflow-x: hidden;
    overscroll-behavior: contain; scroll-behavior: smooth;
    padding: 4px 0;
  }
  .toc-nav::-webkit-scrollbar { width: 6px; }
  .toc-nav::-webkit-scrollbar-track { background: transparent; }
  .toc-nav::-webkit-scrollbar-thumb { background: rgba(255,255,255,.12); border-radius: 3px; }
  .toc-nav::-webkit-scrollbar-thumb:hover { background: rgba(255,255,255,.2); }

  .toc-empty { padding: 24px 16px; text-align: center; }
  .toc-empty p { font-size: 13px; color: #6B7280; }

  .toc-tree, .toc-tree ul { list-style:none; margin:0; padding:0; }

  .toc-tree li { display: flex; flex-direction: column; }

  /* ── Row ── */
  .toc-row {
    display: flex; align-items: center; width: 100%;
    min-height: 44px; padding: 0 16px; cursor: pointer;
    user-select: none; -webkit-user-select: none;
    transition: background 0.12s; outline: none;
    position: relative;
  }
  .toc-row:hover { background: rgba(255,255,255,.06); }
  .toc-row:focus-visible { box-shadow: inset 0 0 0 1px #60A5FA; }

  /* ── Chevron ── */
  .toc-chevron {
    display: inline-flex; align-items: center; justify-content: center;
    width: 20px; height: 20px; flex-shrink: 0; margin-right: 4px;
    color: #6B7280; transition: transform 0.15s; border:none; background:none;
    cursor:pointer; padding:0; border-radius:3px;
  }
  .toc-chevron:hover { background: rgba(255,255,255,.08); color: #E5E7EB; }
  .toc-chevron.expanded { transform: rotate(90deg); }
  .toc-chevron svg { width: 12px; height: 12px; }
  .toc-chevron-placeholder { width: 20px; height: 20px; flex-shrink: 0; margin-right: 4px; }

  /* ── Label ── */
  .toc-label {
    font-size: 14px; line-height: 1.5; color: #9CA3AF;
    white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
    flex: 1; min-width: 0;
  }
  .toc-row.depth-0 .toc-label { font-size: 15px; font-weight: 600; color: #E5E7EB; }
  .toc-row.depth-1 { padding-left: calc(16px + 24px); }
  .toc-row.depth-2 { padding-left: calc(16px + 24px + 16px); }
  .toc-row.depth-2 .toc-label { font-size: 13px; }

  /* ── Active ── */
  .toc-row.active { background: rgba(37,99,235,.15); }
  .toc-row.active::before {
    content: ''; position: absolute; left: 0; top: 4px; bottom: 4px;
    width: 3px; background: #2563EB; border-radius: 0 2px 2px 0;
  }
  .toc-row.active .toc-label { color: #FFFFFF; font-weight: 500; }
  .toc-row.depth-0.active .toc-label { font-weight: 700; }

  /* ── Progress dot ── */
  .toc-progress-dot {
    width: 8px; height: 8px; border-radius: 50%;
    background: #2563EB; flex-shrink: 0; margin-left: 8px;
    display: none;
  }
  .toc-row.active .toc-progress-dot { display: block; }


  /* ── Collapse ── */
  .toc-children { overflow: hidden; }
  .toc-children.collapsed { display: none; }

  /* ── Filtered (hidden by search) ── */
  .toc-tree.filtering .toc-row { display: none; }
  .toc-tree.filtering .toc-row.search-match { display: flex; }
  .toc-tree.filtering .toc-row.search-ancestor { display: flex; }

  /* ═══════════════════════════════════
     Pagination
     ═══════════════════════════════════ */
  .toc-pagination {
    display: flex; align-items: center; justify-content: center;
    gap: 12px; padding: 8px 16px; border-top: 1px solid var(--border, #30363d);
    flex-shrink: 0;
  }
  .toc-page-btn {
    display: flex; align-items: center; justify-content: center;
    width: 32px; height: 28px; border: none; border-radius: 4px;
    background: transparent; color: #9CA3AF; cursor: pointer; transition: background .15s;
  }
  .toc-page-btn:hover { background: rgba(255,255,255,.08); color: #E5E7EB; }
  .toc-page-btn:disabled { opacity: .3; cursor: default; }
  .toc-page-info { font-family: var(--font-mono, monospace); font-size: 11px; color: #6B7280; letter-spacing: .06em; }

  /* ═══════════════════════════════════
     Context menu
     ═══════════════════════════════════ */
  .toc-context-menu {
    position: fixed; z-index: 5000;
    background: #1F2937; border: 1px solid #374151;
    border-radius: 6px; box-shadow: 0 8px 24px rgba(0,0,0,.5);
    padding: 4px; min-width: 160px;
  }
  .toc-context-menu button {
    display: flex; align-items: center; width: 100%;
    padding: 6px 12px; border: none; background: transparent;
    color: #E5E7EB; font-size: 13px; text-align: left;
    border-radius: 4px; cursor: pointer; transition: background .1s;
  }
  .toc-context-menu button:hover { background: rgba(255,255,255,.1); }

  /* ═══════════════════════════════════
     Desktop
     ═══════════════════════════════════ */
  @media (min-width:769px) {
    .toc-backdrop { display: none !important; }
    .toc-close-btn { display: none; }
  }

  /* ═══════════════════════════════════
     Mobile: Drawer
     ═══════════════════════════════════ */
  @media (max-width:768px) {
    .toc-panel {
      position: fixed; top:0; left:0; bottom:0;
      width: 85vw; min-width: unset; max-width: 360px;
      transform: translateX(-100%);
      transition: transform .25s cubic-bezier(.4,0,.2,1);
      z-index: 150; box-shadow: none;
    }
    .toc-panel.open { transform: translateX(0); box-shadow: 4px 0 24px rgba(0,0,0,.4); }
    .toc-backdrop.show { display: block; }
    .toc-drag-handle { display: block; }
    .toc-close-btn { display: flex; }
    .toc-row { min-height: 48px; }
    .toc-nav::-webkit-scrollbar { width: 4px; }
  }
</style>

<script>
  const panel = document.getElementById('toc-panel')!;
  const backdrop = document.getElementById('toc-backdrop')!;
  const closeBtn = document.getElementById('toc-close-btn')!;

  function closeToc(): void { panel.classList.remove('open'); backdrop.classList.remove('show'); }
  function openToc(): void  { panel.classList.add('open'); backdrop.classList.add('show'); }

  closeBtn.addEventListener('click', closeToc);
  backdrop.addEventListener('click', closeToc);

  // 移动端下滑关闭
  let touchStartY = 0;
  panel.addEventListener('touchstart', (e) => {
    const t = e.touches[0];
    if (t.clientX < 40) touchStartY = t.clientY;
  }, { passive: true });
  panel.addEventListener('touchmove', () => { /* track */ }, { passive: true });
  panel.addEventListener('touchend', (e) => {
    const t = e.changedTouches[0];
    if (touchStartY > 0 && t.clientY - touchStartY > 80) closeToc();
    touchStartY = 0;
  });

  // 暴露给 read.astro
  (window as any).__tocOpen  = openToc;
  (window as any).__tocClose = closeToc;
  (window as any).__tocIsOpen = () => panel.classList.contains('open') || window.innerWidth > 768;
  (window as any).__tocPanel = panel;
</script>
