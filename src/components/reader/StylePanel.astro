---
/**
 * StylePanel 组件
 * 右侧样式面板，每书独立
 */
---

<aside class="style-panel" id="style-panel">
  <div class="style-header">
    <span class="style-title">阅读样式</span>
    <button class="style-close" id="btn-style-close" aria-label="关闭">✕</button>
  </div>

  <div class="style-body">
    <div class="style-book-name" id="style-book-name">-</div>

    <!-- 主题 -->
    <div class="style-group">
      <span class="style-label">theme</span>
      <div class="theme-grid" id="theme-grid">
        <button class="theme-swatch" data-theme="dark" aria-label="暗黑">
          <span class="swatch-color" style="background:#0d1117;border:1px solid var(--border);"></span>
          <span class="swatch-name">暗黑</span>
        </button>
        <button class="theme-swatch" data-theme="light" aria-label="明亮">
          <span class="swatch-color" style="background:#ffffff;border:1px solid #d0d7de;"></span>
          <span class="swatch-name">明亮</span>
        </button>
        <button class="theme-swatch" data-theme="sepia" aria-label="护眼">
          <span class="swatch-color" style="background:#f4efe7;border:1px solid #c8b89a;"></span>
          <span class="swatch-name">护眼</span>
        </button>
        <button class="theme-swatch" data-theme="hacker" aria-label="黑客">
          <span class="swatch-color" style="background:#000000;border:1px solid #1a3a1a;"></span>
          <span class="swatch-name">黑客</span>
        </button>
      </div>
    </div>

    <!-- 字号 -->
    <div class="style-group">
      <label class="style-label">
        font size <span class="style-val" id="val-font-size">18</span>
      </label>
      <input type="range" id="range-font-size" class="style-range" min="14" max="26" value="18" step="1" />
    </div>

    <!-- 行距 -->
    <div class="style-group">
      <label class="style-label">
        line height <span class="style-val" id="val-line-height">1.8</span>
      </label>
      <input type="range" id="range-line-height" class="style-range" min="1.4" max="2.2" value="1.8" step="0.1" />
    </div>

    <!-- 段落间距 -->
    <div class="style-group">
      <label class="style-label">
        para spacing <span class="style-val" id="val-para-spacing">1.2</span>
      </label>
      <input type="range" id="range-para-spacing" class="style-range" min="0.5" max="2" value="1.2" step="0.1" />
    </div>

    <!-- 字体 -->
    <div class="style-group">
      <span class="style-label">font</span>
      <div class="btn-group" id="font-group">
        <button class="btn-opt" data-value="sans">Sans</button>
        <button class="btn-opt active" data-value="serif">Serif</button>
        <button class="btn-opt" data-value="mono">Mono</button>
      </div>
    </div>

    <!-- 宽度 -->
    <div class="style-group">
      <span class="style-label">width</span>
      <div class="btn-group" id="width-group">
        <button class="btn-opt" data-value="480">窄</button>
        <button class="btn-opt active" data-value="640">中</button>
        <button class="btn-opt" data-value="800">宽</button>
      </div>
    </div>

    <!-- Toggle -->
    <div class="style-group">
      <div class="style-row">
        <span class="style-label">indent</span>
        <label class="toggle"><input type="checkbox" id="toggle-indent" /><span class="toggle-slider"></span></label>
      </div>
      <div class="style-row">
        <span class="style-label">vertical</span>
        <label class="toggle"><input type="checkbox" id="toggle-vertical" /><span class="toggle-slider"></span></label>
      </div>
    </div>

    <!-- 操作按钮 -->
    <div class="style-actions">
      <button class="style-btn style-btn--secondary" id="btn-reset-style">重置默认</button>
      <button class="style-btn style-btn--primary" id="btn-apply-all">应用到所有书</button>
    </div>
  </div>
</aside>

<style>
  .style-panel {
    width: 260px;
    min-width: 260px;
    background: var(--bg-surface);
    border-left: 1px solid var(--border);
    display: flex;
    flex-direction: column;
    overflow-y: auto;
    flex-shrink: 0;
  }

  .style-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: var(--space-2) var(--space-4);
    border-bottom: 1px solid var(--border);
    height: 44px;
  }

  .style-title {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.06em;
    color: var(--text-secondary);
    text-transform: lowercase;
  }

  .style-close {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 24px;
    height: 24px;
    border: 1px solid var(--border);
    border-radius: var(--radius);
    background: transparent;
    color: var(--text-muted);
    cursor: pointer;
    font-size: 12px;
    transition: all 0.15s ease;
  }

  .style-close:hover { color: var(--accent-red); border-color: var(--accent-red); }

  .style-body {
    padding: var(--space-4);
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
  }

  .style-book-name {
    font-size: 13px;
    color: var(--text-primary);
    text-align: center;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    padding-bottom: var(--space-2);
    border-bottom: 1px solid var(--border);
  }

  .style-group { display: flex; flex-direction: column; gap: var(--space-2); }
  .style-row { display: flex; align-items: center; justify-content: space-between; }

  .style-label {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.06em;
    color: var(--text-muted);
    text-transform: lowercase;
    display: flex;
    align-items: center;
    gap: var(--space-2);
  }

  .style-val { color: var(--accent-blue); }

  .style-range {
    width: 100%;
    height: 4px;
    -webkit-appearance: none;
    appearance: none;
    background: var(--bg-card);
    border-radius: 2px;
    outline: none;
    cursor: pointer;
  }

  .style-range::-webkit-slider-thumb {
    -webkit-appearance: none;
    width: 14px;
    height: 14px;
    border-radius: 50%;
    background: var(--accent-blue);
    border: 2px solid var(--bg-surface);
    cursor: pointer;
  }

  /* 主题色块 */
  .theme-grid { display: grid; grid-template-columns: 1fr 1fr; gap: var(--space-2); }
  .theme-swatch {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    padding: var(--space-2);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    background: var(--bg-card);
    cursor: pointer;
    transition: all 0.15s ease;
  }
  .theme-swatch:hover { border-color: var(--border-strong); }
  .theme-swatch.active { border-color: var(--accent-blue); box-shadow: 0 0 0 1px var(--accent-blue); }
  .swatch-color { width: 20px; height: 20px; border-radius: calc(var(--radius) - 2px); display: block; flex-shrink: 0; }
  .swatch-name { font-family: var(--font-mono); font-size: 10px; letter-spacing: 0.06em; color: var(--text-secondary); }

  /* 按钮组 */
  .btn-group {
    display: flex;
    gap: 2px;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 2px;
  }
  .btn-opt {
    flex: 1;
    padding: var(--space-1) var(--space-2);
    border: 1px solid transparent;
    border-radius: calc(var(--radius) - 1px);
    background: transparent;
    color: var(--text-secondary);
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.06em;
    cursor: pointer;
    transition: all 0.15s ease;
  }
  .btn-opt:hover { color: var(--text-primary); }
  .btn-opt.active { background: var(--bg-surface); border-color: var(--accent-blue); color: var(--accent-blue); }

  /* Toggle */
  .toggle { position: relative; display: inline-block; width: 36px; height: 20px; cursor: pointer; }
  .toggle input { opacity: 0; width: 0; height: 0; }
  .toggle-slider {
    position: absolute;
    inset: 0;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 10px;
    transition: all 0.15s ease;
  }
  .toggle-slider::after {
    content: '';
    position: absolute;
    top: 2px;
    left: 2px;
    width: 14px;
    height: 14px;
    border-radius: 50%;
    background: var(--text-muted);
    transition: all 0.15s ease;
  }
  .toggle input:checked + .toggle-slider { background: var(--accent-blue); border-color: var(--accent-blue); }
  .toggle input:checked + .toggle-slider::after { background: var(--bg-surface); transform: translateX(16px); }

  /* 操作按钮 */
  .style-actions {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    padding-top: var(--space-4);
    border-top: 1px solid var(--border);
  }
  .style-btn {
    width: 100%;
    padding: var(--space-2);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    background: var(--bg-card);
    color: var(--text-secondary);
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.06em;
    cursor: pointer;
    transition: all 0.15s ease;
  }
  .style-btn:hover { border-color: var(--border-strong); color: var(--text-primary); }
  .style-btn--primary { border-color: var(--accent-blue); color: var(--accent-blue); }

  @media (max-width: 768px) {
    .style-panel {
      position: fixed;
      right: 0;
      top: 44px;
      bottom: 0;
      z-index: 100;
      transform: translateX(100%);
      transition: transform 0.2s ease;
    }
    .style-panel.open { transform: translateX(0); }
  }
</style>
